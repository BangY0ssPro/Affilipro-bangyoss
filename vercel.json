{
  "version": 2,
  "name": "affilipro-bangyoss",
  "functions": {
    "api/sheets.js": { "memory": 512, "maxDuration": 15 },
    "api/drive.js":  { "memory": 256, "maxDuration": 10 }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": {
        "Access-Control-Allow-Origin":  "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
